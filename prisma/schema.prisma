datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id        String      @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String
  phone     String
  address   String
  products  Product[]
}

model Product {
  id          String      @id @default(uuid())
  title       String
  description String
  price       Float
  image       String?
  category    String?
  address     String
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}